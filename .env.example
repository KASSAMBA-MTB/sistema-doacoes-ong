# Segurança
SECRET_KEY=
DEBUG=True

BASE_URL=

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=

# Banco de Dados PostgreSQL
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Observação:
# Em execução normal, PostgreSQL é obrigatório.
# SQLite é usado automaticamente apenas durante testes (manage.py test).

# E-mail (alertas de validade)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@colo-de-mae.local

# Alertas de estoque perecível
# Separar múltiplos e-mails por vírgula
ESTOQUE_ALERTA_EMAIL_DESTINATARIOS=
ESTOQUE_ALERTA_EMAIL_INTERVALO_HORAS=24
